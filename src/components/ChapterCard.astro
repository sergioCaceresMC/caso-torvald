---
import type { Chapter } from "../data/chapters";
import { COMMAND_INFO } from "../data/chapters";

type Props = Chapter;

const {
  chapter,
  numeral,
  title,
  subtitle,
  room,
  image,
  image2,
  evidence,
  commands,
  story,
  hint,
  isFirst = false,
} = Astro.props;
---

<article
  class:list={["chapter-card", isFirst ? "unlocked" : "locked"]}
  id={`chapter-${chapter}`}
  data-chapter={chapter}
>
  <!-- Left column: stacked evidence photos (hover reveals the one behind) -->
  <figure class="evidence" data-room={room}>
    <div class="evidence-stage">
      <!-- Second reference print, peeks out from behind on hover -->
      <div class="photo photo-back" aria-hidden="true">
        <img
          class="evidence-img2"
          src={image2}
          alt=""
          loading="lazy"
          decoding="async"
          onerror="this.closest('.photo-back').style.display='none'"
        />
      </div>

      <div class="photo photo-front">
        <img
          class="evidence-img"
          src={image}
          alt={`Fotografía de la escena: ${title}`}
          loading="lazy"
          decoding="async"
          onerror="this.closest('.evidence').classList.add('img-failed')"
        />
        <span class="evidence-noimg" aria-hidden="true">{title}</span>
        <span class="evidence-stamp"
          >Exp. Nº {String(chapter).padStart(3, "0")}</span
        >
        <span class="status-chip lock-chip">Sellado</span>
        <span class="status-chip unlock-chip">Abierto</span>
      </div>
    </div>
    <figcaption class="evidence-caption">{evidence}</figcaption>
  </figure>

  <!-- Right column: case content -->
  <div class="case-content">
    <header class="case-head">
      <span class="chapter-pill">Capítulo {numeral}</span>
      <h2 class="chapter-title"><span class="title-mark">{title}</span></h2>
      <p class="chapter-subtitle">{subtitle}</p>
    </header>

    <p class="locked-caption">
      Expediente sellado. Resuelve el capítulo anterior para abrirlo.
    </p>

    <div class="case-body">
      <div class="story">
        <p set:html={story} />
      </div>

      <div class="commands-section">
        <h3>Comandos de este capítulo</h3>
        <div class="cmd-tags">
          {
            commands.map((cmd) => (
              <button
                type="button"
                class="cmd-tag"
                data-explain={
                  COMMAND_INFO[cmd] ?? "Comando del terminal de Linux."
                }
              >
                {cmd}
              </button>
            ))
          }
        </div>
        <p class="cmd-explain" aria-live="polite">
          Pulsa un comando para ver qué hace.
        </p>
      </div>

      <div class="hint-box">
        <span class="hint-label">Nota al margen</span>
        <span set:html={hint} />
      </div>

      <div class="pw-section">
        <p class="pw-label">Contraseña hallada en <em>{title}</em>:</p>
        <div class="pw-row">
          <input
            type="text"
            class="pw-input"
            placeholder="· · · · · · · · · ·"
            autocomplete="off"
            spellcheck="false"
            aria-label={`Contraseña del capítulo ${numeral}`}
          />
          <button class="pw-btn">Verificar</button>
        </div>
        <p class="pw-feedback" aria-live="polite"></p>
      </div>
    </div>
  </div>
</article>

<style>
  /* One chapter = one page. Only the active card is shown. */
  .chapter-card {
    display: none;
    width: 100%;
    height: 100%;
    background: var(--card);
    background-image: var(--paper-grain);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .chapter-card.active {
    display: flex;
    animation: cardIn 0.4s ease-out;
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Left: evidence photo ── */
  .evidence {
    flex: 0 0 38%;
    min-width: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    padding: 1.1rem;
    border-right: 1px dashed var(--border-strong);
    background: var(--card-2);
  }

  /* Two stacked prints; the back one fans out on hover */
  .evidence-stage {
    position: relative;
    flex: 1;
    min-height: 0;
  }

  .photo {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--card-2);
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-back {
    z-index: 1;
    filter: sepia(0.45) brightness(0.9);
    transition:
      transform 0.45s ease,
      box-shadow 0.45s ease;
  }
  .photo-front {
    z-index: 2;
    transition: transform 0.45s ease;
  }
  .photo-front .evidence-img {
    filter: sepia(0.3) contrast(1.02) brightness(0.97);
    transition: filter 0.5s ease;
  }

  /* Hover: fan the two prints apart so the reference photo shows behind */
  /*
  .chapter-card:hover .photo-back {
    transform: rotate(6.5deg) translate(4%, 5%);
    box-shadow: var(--lift);
  }
  .chapter-card:hover .photo-front {
    transform: rotate(-2deg);
  }*/

  .evidence:hover .photo-back {
    transform: rotate(6.5deg) translate(4%, 5%);
    box-shadow: var(--lift);
  }
  .evidence:hover .photo-front {
    transform: rotate(-2deg);
  }
  .chapter-card.unlocked:hover .photo-front .evidence-img {
    filter: sepia(0) contrast(1) brightness(1);
  }
  .chapter-card.locked .evidence-img {
    filter: grayscale(0.85) brightness(0.95);
  }

  /* Fallback if the photo fails to load (no broken image, no emoji) */
  .evidence-noimg {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
    font-family: var(--font-title);
    font-weight: 600;
    color: var(--ink-muted);
    background:
      var(--paper-grain),
      repeating-linear-gradient(
        45deg,
        var(--card-2) 0 14px,
        var(--paper-2) 14px 28px
      );
  }
  .evidence.img-failed .evidence-img {
    display: none;
  }
  .evidence.img-failed .evidence-noimg {
    display: flex;
  }

  /* Red case-file stamp */
  .evidence-stamp {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-stamp);
    border: 1.5px solid var(--ink-stamp);
    padding: 0.12rem 0.4rem;
    background: rgba(255, 253, 247, 0.82);
    transform: rotate(3deg);
  }

  .status-chip {
    position: absolute;
    bottom: 0.6rem;
    left: 0.6rem;
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.6rem;
  }
  .lock-chip {
    background: rgba(26, 24, 19, 0.72);
    color: #fff;
  }
  .unlock-chip {
    display: none;
    background: var(--amber-deep);
    color: var(--ink);
  }
  .chapter-card.unlocked .lock-chip {
    display: none;
  }
  .chapter-card.unlocked .unlock-chip {
    display: block;
  }

  .evidence-caption {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-style: italic;
    color: var(--ink-muted);
    text-align: center;
    padding-top: 0.6rem;
  }

  /* ── Right: case content (scrolls internally if it must) ── */
  .case-content {
    flex: 1;
    min-width: 0;
    overflow-y: auto;
    padding: 1.6rem 1.7rem;
  }

  .case-head {
    margin-bottom: 1.1rem;
  }

  /* Chapter NUMBER — previous yellow background, black text */
  .chapter-pill {
    display: inline-block;
    background: var(--yellow);
    border: 1px solid var(--yellow-deep);
    color: var(--ink);
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    padding: 0.24rem 0.8rem;
  }

  .chapter-title {
    margin: 0;
    font-size: 1.7rem;
    line-height: 1.2;
  }

  /* Chapter NAME — orange (amber) background, black text */
  .title-mark {
    display: inline-block;
    background: var(--amber);
    color: var(--ink);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    padding: 0.12em 0.45em 0.16em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .chapter-subtitle {
    background-color: rgb(255, 252, 248);
    padding: 10px;
    font-size: 0.98rem;
    color: var(--ink-soft);
    line-height: 1.65;
  }

  /* ── Locked state ── */
  .locked-caption {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-strong);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--ink-muted);
  }
  .chapter-card.unlocked .locked-caption {
    display: none;
  }

  /* Body appears once unlocked, styled as a handwritten letter on ruled paper */
  .case-body {
    display: none;
    position: relative;
    background-color: #fbf6e3;
    background-image:
      linear-gradient(
        to right,
        transparent 2.1rem,
        rgba(176, 64, 47, 0.3) 2.1rem,
        rgba(176, 64, 47, 0.3) calc(2.1rem + 1px),
        transparent calc(2.1rem + 1px)
      ),
      repeating-linear-gradient(
        to bottom,
        transparent 0 1.85rem,
        rgba(26, 24, 19, 0.06) 1.85rem calc(1.85rem + 1px)
      );
    border: 1px solid var(--border-strong);
    box-shadow: var(--lift-sm);
    padding: 1.6rem 1.6rem 1.6rem 3rem;
  }
  .chapter-card.unlocked .case-body {
    display: block;
  }

  /* Handwritten-style story */
  .story {
    font-style: italic;
    font-size: 1.08rem;
    color: var(--ink);
    margin: 0 0 1.7rem;
    line-height: 1.85;
  }
  .story :global(strong) {
    font-style: italic;
  }

  /* ── Commands ── */
  .commands-section {
    margin-bottom: 1.4rem;
  }
  .commands-section h3 {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    margin-bottom: 0.7rem;
  }
  .cmd-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .cmd-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--amber-soft);
    border: 1px solid var(--amber-deep);
    color: var(--amber-dark);
    padding: 0.24rem 0.6rem;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }
  .cmd-tag:hover {
    transform: translateY(-2px);
    background: var(--amber-tint);
  }
  .cmd-tag.is-active {
    background: var(--amber);
    color: var(--ink);
    font-weight: 700;
  }

  /* Explanation revealed when a command is clicked */
  .cmd-explain {
    margin-top: 0.8rem;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--ink-soft);
    background: var(--card);
    border-left: 3px solid var(--amber);
    padding: 0.55rem 0.85rem;
    line-height: 1.55;
  }

  /* ── Hint — margin note ── */
  .hint-box {
    position: relative;
    background: var(--amber-tint);
    border: 1px solid var(--amber-deep);
    border-left: 4px solid var(--amber);
    padding: 1.1rem 1rem 0.85rem;
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
    line-height: 1.65;
  }
  .hint-label {
    position: absolute;
    top: -0.62rem;
    left: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--amber-dark);
    background: var(--card);
    padding: 0 0.4rem;
  }

  /* ── Password — the ONLY rounded area ── */
  .pw-section {
    border-top: 1px dashed var(--border-strong);
    padding-top: 1.3rem;
  }
  .pw-label {
    font-size: 0.9rem;
    color: var(--ink-muted);
    margin-bottom: 0.65rem;
  }
  .pw-label em {
    color: var(--ink);
    font-style: normal;
    font-weight: 700;
  }

  .pw-row {
    display: flex;
    align-items: stretch;
    background: var(--card);
    border: 2px solid var(--amber-deep);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }
  .pw-row:focus-within {
    box-shadow: var(--lift);
  }

  .pw-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.8rem 1.1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    outline: none;
  }
  .pw-input::placeholder {
    color: var(--ink-faint);
    letter-spacing: 0.12em;
    font-size: 0.8rem;
  }
  .pw-input:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .pw-btn {
    background: var(--amber);
    border: none;
    border-left: 2px solid var(--amber-deep);
    color: var(--ink);
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 1.5rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }
  .pw-btn:hover:not(:disabled) {
    background: var(--amber-deep);
  }
  .pw-btn:active:not(:disabled) {
    filter: brightness(0.96);
  }
  .pw-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pw-feedback {
    margin-top: 0.6rem;
    font-size: 0.84rem;
    min-height: 1.2em;
    font-family: var(--font-mono);
  }
  .pw-feedback.success {
    color: var(--success-text);
  }
  .pw-feedback.error {
    color: var(--error-text);
  }

  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-8px);
    }
    40% {
      transform: translateX(8px);
    }
    60% {
      transform: translateX(-5px);
    }
    80% {
      transform: translateX(4px);
    }
  }
  .pw-input.shake {
    animation: shake 0.5s ease-in-out;
  }

  /* ── Stacked layout on narrow screens ── */
  @media (max-width: 760px) {
    .chapter-card {
      height: auto;
      flex-direction: column;
    }
    .evidence {
      flex: none;
      border-right: none;
      border-bottom: 1px dashed var(--border-strong);
    }
    .evidence-photo {
      aspect-ratio: 16 / 10;
      flex: none;
    }
    .case-content {
      overflow: visible;
    }
  }

  @media (max-width: 520px) {
    .pw-row {
      flex-direction: column;
    }
    .pw-btn {
      border-left: none;
      border-top: 2px solid var(--amber-deep);
    }
  }
</style>
