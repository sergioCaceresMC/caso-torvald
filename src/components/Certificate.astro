---
interface Props {
  date?: string;
  verdictName?: string;
  verdictLabel?: string;
  detective?: string;
  code?: string;
}

const {
  date = "Mansión Torvald — 13 de octubre de 2024",
  verdictName = "Lady Isolde Torvald",
  verdictLabel = "Culpable — Homicidio en primer grado",
  detective = "Marcos Kernel",
  code = "CASO_RESUELTO_TORVALD_2024",
} = Astro.props;
---

<section id="certificate" class="certificate" aria-live="polite">
  <div class="cert-seal">Expediente cerrado</div>
  <h2>Caso Resuelto</h2>
  <p class="cert-subtitle">{date}</p>

  <div class="cert-divider"></div>

  <div class="cert-verdict">
    <p>{verdictName}</p>
    <p class="verdict-label">{verdictLabel}</p>
  </div>

  <div class="cert-divider"></div>

  <div class="cert-detective">
    <p>Caso resuelto por el Detective</p>
    <p class="det-name">{detective}</p>
  </div>

  <div class="cert-code-section">
    <p>Código de caso cerrado</p>
    <code class="cert-code">{code}</code>
  </div>
</section>

<style>
  /* Shown as a page in the stepper — hidden until activated */
  .certificate {
    display: none;
    position: relative;
    width: 100%;
    max-width: 620px;
    margin: auto;
    border: 2px solid var(--amber-deep);
    background:
      var(--paper-grain),
      linear-gradient(160deg, var(--amber-tint) 0%, var(--card) 55%);
    padding: 2.5rem;
    text-align: center;
    overflow-y: auto;
  }
  .certificate.active {
    display: block; 
    animation: fadeIn 0.5s ease-out;
  }

  /* Decorative inner rule — like an official document border */
  .certificate::before {
    content: "";
    position: absolute;
    inset: 10px;
    border: 1px dashed var(--amber-deep);
    pointer-events: none;
    opacity: 0.55;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Red "case closed" stamp (no emoji) */
  .cert-seal {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-stamp);
    border: 2px solid var(--ink-stamp);
    padding: 0.3rem 0.9rem;
    margin-bottom: 1rem;
    transform: rotate(-3deg);
  }

  .certificate h2 {
    font-size: 1.9rem;
    color: var(--ink);
    margin-bottom: 0.3rem;
  }

  .cert-subtitle {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cert-divider {
    width: 80px;
    height: 3px;
    background: var(--amber);
    border-radius: 3px;
    margin: 1.5rem auto;
  }

  .cert-verdict {
    background: rgba(138, 44, 34, 0.06);
    border: 1px solid var(--ink-stamp);
    padding: 1rem 1.5rem;
    margin: 0 auto 0.5rem;
    display: inline-block;
    min-width: 280px;
  }

  .cert-verdict p:first-child {
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }

  .cert-verdict .verdict-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-stamp);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }

  .cert-detective p {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .det-name {
    font-family: var(--font-title) !important;
    font-weight: 700;
    font-size: 1.4rem !important;
    color: var(--ink) !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    margin-top: 0.2rem;
  }

  .cert-code-section {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border-strong);
    padding: 1rem;
    margin-top: 1.5rem;
  }

  .cert-code-section p {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .cert-code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--amber-dark);
    letter-spacing: 0.1em;
    border: none;
    background: none;
    padding: 0;
  }
</style>
