---
import logo from "../assets/logo.webp";

interface Props {
  /** Total number of chapters, used in the progress badge. */
  total?: number;
  /** Show the game-specific controls (progress badge + reset). Off on the
      landing page, on inside the case. */
  showGameControls?: boolean;
}
const { total = 6, showGameControls = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <a class="site-title" href={base} aria-label="El Caso Torvald — Inicio">
    <img src={logo.src} alt="logo" class="site-emblem" >
    <span class="site-name">El Caso Torvald</span>
  </a>

  <div class="header-controls">
    <a
      class="mitha-link"
      href="http://proyecto-mitha.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      Visitar <span class="mitha">MïTHA</span>
    </a>

    {showGameControls && (
      <>
        <p class="progress-badge">
          Progreso: <span id="progress-count">1/{total}</span>
        </p>
        <button id="reset-btn" title="Reiniciar el caso">
          Reiniciar caso
        </button>
      </>
    )}
  </div>
</header>

<style>
  .site-header {
    background: rgba(0, 0, 0, 0.95);
    color: white;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(14px) saturate(1.2);
    margin-bottom: 20px;
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s ease;
  }

  .site-title:hover {
    transform: translateY(-2px);
  }

  /* Emblema estilo expediente/investigación */
  .site-emblem {
    position: relative;
    width: 1.7rem;
    height: 1.7rem;
    background: var(--amber);
    flex-shrink: 0;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .site-emblem::before {
    content: '';
    position: absolute;
    inset: 5px;
    background: var(--ink);
  }

  .site-title:hover .site-emblem {
    transform: rotate(-8deg) scale(1.08);
  }

  .site-name {
    font-family: var(--font-title);
    font-size: 1.18rem;
    letter-spacing: -0.01em;
    transition: color 0.25s ease;
  }

  .site-title:hover .site-name {
    color: var(--amber);
  }

  .site-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--amber-dark);
    background: var(--amber-soft);
    border: 1px solid var(--amber-deep);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.16rem 0.5rem;
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mitha{
    margin-left: 0.2rem;
    font-family: var(--font-mitha);
  }

  .mitha-link {
    font-size: 0.9rem;
    color: #fff;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 0.4rem 0.85rem;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .mitha-link:hover {
    color: var(--amber);
    border-color: var(--amber-deep);
    transform: translateY(-2px);
  }

  .progress-badge {
    font-family: var(--font-title);
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    margin: 0;
    margin-right: 5px;
    opacity: 0.9;
  }

  #progress-count {
    display: inline-block;
    font-weight: 700;
    margin-left: 0.2rem;
  }

  #reset-btn {
    background: var(--amber-deep);
    color: var(--ink);
    font-family: var(--font-title);
    font-weight: 500;
    padding: 0.45rem 0.95rem;
    border-radius: 8px;
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease;
  }

  #reset-btn:hover {
    transform: translateY(-3px) scale(1.05);   
  }

  #reset-btn:active {
    transform: translateY(-1px) scale(1.02);
  }

  @media (max-width: 600px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem;
    }

    .header-controls {
      width: 100%;
      justify-content: space-between;
    }

    .site-name {
      font-size: 1.1rem;
    }
  }
</style>